{
  "version": "2.0.2",
  "version_name": "2.0.2 active tab contrast",
  "name": "$name Custom",
  "manifest_version": 3,

  "theme": {
    "images": {
      "theme_frame": "swatches/$(base|base|overlay).png",
      "theme_frame_inactive": "swatches/$(base|base|overlay).png",
      "theme_toolbar": "swatches/base.png",
      "theme_tab_background": "swatches/$(base|base|overlay).png",
      "theme_tab_background_inactive": "swatches/$(base|base|overlay).png",
      "theme_frame_incognito": "swatches/med.png"
    },

    "colors": {
      "frame": $($base|$base|$overlay),
      "frame_inactive": $($base|$base|$overlay),
      "background_tab": $($base|$base|$overlay),
      "background_tab_inactive": $($base|$base|$overlay),
      "bookmark_text": $text,
      "button_background": $base,
      "tab_background_text": $subtle,
      "tab_background_text_inactive": $muted,
      "tab_text": $text,
      "toolbar": $base,
      "toolbar_button_icon": $text,

      "frame_incognito": [0, 0, 0],
      "frame_incognito_inactive": $highlightMed,
      "tab_background_text_incognito": $text,
      "tab_background_text_incognito_inactive": $subtle,

      "omnibox_text": $($rose|$iris|$pine),
      "omnibox_background": $base,

      "ntp_background": $base,
      "ntp_header": $surface,
      "ntp_link": $subtle,
      "ntp_text": $subtle
    },

    "tints": {
      "buttons": [-1, -1, -1],
      "frame": [-1, -1, -1],
      "frame_inactive": [-1, -1, -1],
      "frame_incognito": [-1, -1, -1],
      "frame_incognito_inactive": [-1, -1, -1]
    },

    "properties": {
      "ntp_background_alignment": "bottom",
      "ntp_logo_alternate": 1
    }
  }
}
